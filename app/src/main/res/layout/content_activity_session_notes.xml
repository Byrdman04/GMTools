<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/parchment_paper"
    android:padding="16dp">

    <!-- ========================= -->
    <!-- Session List Screen -->
    <!-- ========================= -->

    <LinearLayout
        android:id="@+id/sessionListContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/chooseNotesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Notes:"
            android:textColor="@android:color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <ListView
            android:id="@+id/sessionListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"/>

    </LinearLayout>


    <!-- ========================= -->
    <!-- File Viewer Screen -->
    <!-- ========================= -->

    <ScrollView
        android:id="@+id/fileViewerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/fileContentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:lineSpacingExtra="4dp"
            tools:text="File contents will appear here."/>

    </ScrollView>

</FrameLayout>