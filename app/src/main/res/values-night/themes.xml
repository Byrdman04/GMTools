<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.GMTools"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- App colors -->
        <item name="colorPrimary">#6B3F1D</item> <!-- brown -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="colorSecondary">#C9A227</item> <!-- gold -->
        <item name="colorOnSecondary">#000000</item>

        <item name="colorTertiary">#8A8A8A</item>

        <!-- Background -->
        <item name="android:colorBackground">#2F2F2F</item>
        <item name="colorSurface">#3A3A3A</item>
        <item name="colorOnSurface">#FFFFFF</item>

        <!-- Global Button Style -->
        <item name="materialButtonStyle">@style/Widget.GMTools.Button</item>

    </style>

    <!-- Button styling -->
    <style name="Widget.GMTools.Button"
        parent="Widget.Material3.Button">

        <!-- Brown fill -->
        <item name="backgroundTint">#6B3F1D</item>

        <!-- White text -->
        <item name="android:textColor">#FFFFFF</item>

        <!-- Gold outline -->
        <item name="strokeColor">#C9A227</item>
        <item name="strokeWidth">2dp</item>

        <!-- Slight rounding -->
        <item name="cornerRadius">10dp</item>

    </style>

    <style name="Theme.GMTools" parent="Base.Theme.GMTools" />

</resources>